Thumbs.db

# Data - archivos grandes (usar scripts/download_drive_assets.py para reproducir)
# Pesos FoundationPose y GDR-Net pesados: descargables desde Drive
data/models/foundationpose/**/*.pth
data/models/gdrnet/**/*.pth
data/models/*.onnx
data/models/*.bin
# Permitir explícitamente: configs YAML de los pesos y modelos pequeños entrenados (< 10 MB)
!data/models/foundationpose/**/config.yml
!data/models/gdrnet/**/config.yml
!data/models/diffusion_policy_grasp.pth
# Datasets BOP: descargables desde HuggingFace (notebooks/colab/00_setup)
data/datasets/
*.hdf5
*.h5

# Papers PDFs (no subir por copyright)
papers/*.pdf

# Resultados temporales (mantener JSONs y PNGs finales)
experiments/logs/
!experiments/results/
!experiments/results/**/*.json
!experiments/results/**/*.png
!experiments/results/**/*.md
*.log

# FoundationPose eval: los checkpoints son artefactos reanudables (MB), no respaldo final.
# Los comparison_*.json y predictions_*.json sí se versionan (son la evidencia del TFM).
experiments/results/foundationpose_eval/*_checkpoint.json
experiments/results/foundationpose_eval/fp_*_checkpoint.json

# Secretos y credenciales
.env
*.key
credentials.json

# Documentos compilados
docs/*.pdf

# ROS 2 build
install/
log/
build/

# CoppeliaSim
*.ttt.bak

# Frames raw del video E2E (regenerables con scripts de record_e2e_video_*.py)
# Solo se versionan los productos finales: demo_*.mp4, demo_*.gif, highlights_*/
experiments/results/pipeline_e2e/demo_frames/
experiments/results/pipeline_e2e/demo_v2_frames/
experiments/results/pipeline_e2e/demo_v3_frames/
