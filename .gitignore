# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Data - archivos grandes (usar scripts/download_drive_assets.py para reproducir)
# Pesos FoundationPose y GDR-Net pesados: descargables desde Drive
data/models/foundationpose/**/*.pth
data/models/gdrnet/**/*.pth
data/models/*.onnx
data/models/*.bin
# Permitir explícitamente: configs YAML de los pesos y modelos pequeños entrenados (< 10 MB)
!data/models/foundationpose/**/config.yml
!data/models/gdrnet/**/config.yml
!data/models/diffusion_policy_grasp.pth
# Datasets BOP: descargables desde HuggingFace (notebooks/colab/00_setup)
data/datasets/
*.hdf5
*.h5

# Papers PDFs (no subir por copyright)
papers/*.pdf

# Resultados temporales (mantener JSONs y PNGs finales)
experiments/logs/
!experiments/results/
!experiments/results/**/*.json
!experiments/results/**/*.png
!experiments/results/**/*.md
*.log

# FoundationPose eval: los checkpoints son artefactos reanudables (MB), no respaldo final.
# Los comparison_*.json y predictions_*.json sí se versionan (son la evidencia del TFM).
experiments/results/foundationpose_eval/*_checkpoint.json
experiments/results/foundationpose_eval/fp_*_checkpoint.json

# Secretos y credenciales
.env
*.key
credentials.json

# Documentos compilados
docs/*.pdf

# ROS 2 build
install/
log/
build/

# CoppeliaSim
*.ttt.bak

# Frames raw del video E2E (regenerables con scripts de record_e2e_video_*.py)
# Solo se versionan los productos finales: demo_*.mp4, demo_*.gif, highlights_*/
experiments/results/pipeline_e2e/demo_frames/
experiments/results/pipeline_e2e/demo_v2_frames/
experiments/results/pipeline_e2e/demo_v3_frames/
packages/*/dist/
packages/*/build/
packages/*/*.egg-info/
packages/*/.coverage
.coverage

# Pick battery: frames intermedios regenerables (mantener solo MP4)
experiments/results/pick_battery/*/frames/
experiments/results/pick_demo/frames/
experiments/results/pick_with_fp_pose/frames/
# Iter1 frames (regenerables con run_pick_with_diffusion.py)
experiments/results/pick_with_diffusion/frames/

# Datasets de Iter1 retrain (regenerables con collect_diffusion_dataset.py)
data/datasets/sim_pick_*/

# Checkpoints de Iter1 (regenerables; el original sí se commit)
data/models/diffusion_policy_sim_v1.pth
data/models/diffusion_policy_sim_v1.summary.json

# Iter 2 checkpoint (regenerable)
data/models/diffusion_policy_sim_v2.pth
data/models/diffusion_policy_sim_v2.summary.json

# Iter 3 checkpoints (regenerables)
data/models/diffusion_policy_sim_v3.pth
data/models/diffusion_policy_sim_v3.summary.json
data/models/visual_encoder_iter3.pth

# Iter 4 checkpoints (regenerables)
data/models/diffusion_policy_sim_v4.pth
data/models/diffusion_policy_sim_v4.summary.json
data/models/visual_encoder_iter4.pth

# Demo reel: MP4 generados (regenerables con build_demo_reel.py)
experiments/results/demo_reel/
!experiments/results/demo_reel/README.md
# Frames intermedios de los demos (regenerables re-corriendo el sim)
experiments/results/**/frames/
# Staging reversible de la limpieza (pendiente de borrado definitivo)
experiments/results/_frames_archive/
experiments/results/_orphans_review/
